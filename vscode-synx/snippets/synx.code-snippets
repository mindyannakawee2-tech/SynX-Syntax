{
  "work function": {
    "prefix": "work",
    "body": [
      "work ${1:name}(${2:args}) {",
      "  ${3:export nil}",
      "}"
    ],
    "description": "Create a SynX work function"
  },
  "set variable": {
    "prefix": "set",
    "body": ["set ${1:name} = ${2:value}"],
    "description": "Create a SynX set binding"
  },
  "if block": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "  ${2}",
      "}"
    ],
    "description": "Create an if block"
  }
}
